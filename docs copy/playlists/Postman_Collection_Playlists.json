              "raw": "{\n  \"name\": \"Afternoon Chill\",\n  \"storeId\": \"s0000000-0000-0000-0000-000000000001\",\n  \"moodId\": null,\n  \"description\": \"Soft background music for afternoon hours\",\n  \"isDefault\": false,\n  \"trackIds\": [\n    \"a1b2c3d4-0001-0000-0000-000000000001\",\n    \"a1b2c3d4-0002-0000-0000-000000000002\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
