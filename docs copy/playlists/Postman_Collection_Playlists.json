            ],
            "url": {
              "raw": "{{baseUrl}}/api/playlists/{{playlistId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "playlists", "{{playlistId}}"]
            },
            "description": "Get full playlist detail including ordered tracks with HLS seek offsets.\n\nAuth: SystemAdmin ✅, BrandManager (own brand) ✅, StoreManager (own store) ✅, PlaybackDevice ✅ (chỉ khi playlist.StoreId = Store của session; dùng Bearer {{deviceAccessToken}}).\n\nIncludes: PlaylistTracks → Track, Mood, Store navigation.\n\nseekOffsetSeconds is computed server-side (cumulative sum of actualDurationSec ?? durationSec).\nUse seekOffsetSeconds to implement SkipToTrack by seeking the HLS player."
          },
          "response": [
            {
              "name": "200 OK — Playlist detail",
              "originalRequest": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }],
                "url": {
                  "raw": "{{baseUrl}}/api/playlists/{{playlistId}}",
