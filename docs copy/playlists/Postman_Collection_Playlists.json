      "key": "deviceAccessToken",
      "value": "",
      "type": "string",
      "description": "JWT Bearer token (PlaybackDevice — tablet đã pair). Dùng cho GET playlists / GET playlist by id (scope Store của session)."
    }
  ],
  "item": [
    {
      "name": "Playlists",
      "item": [
        {
          "name": "Get Playlists (Paginated)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Accept-Language",
                "value": "vi-VN",
                "type": "text",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/playlists?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "playlists"],
              "query": [
                { "key": "page", "value": "1", "description": "Current page (default: 1)" },
                { "key": "pageSize", "value": "10", "description": "Items per page (default: 10, max: 500)" },
                { "key": "search", "value": "", "description": "Search by name, description", "disabled": true },
                { "key": "sortBy", "value": "", "description": "Field to sort by (e.g. name, createdAt)", "disabled": true },
                { "key": "isAscending", "value": "false", "description": "Sort direction (default: false = newest first)", "disabled": true },
                { "key": "status", "value": "1", "description": "Filter by status: 0=Inactive, 1=Active, 2=Pending, 3=Rejected", "disabled": true },
                { "key": "brandId", "value": "", "description": "⚠️ BM/SM: always overridden to their own brand. SA: free filter", "disabled": true },
                { "key": "storeId", "value": "", "description": "⚠️ SM: always overridden to their own store. BM: filter within brand. SA: free filter", "disabled": true },
                { "key": "moodId", "value": "", "description": "Filter by mood (Guid)", "disabled": true },
                { "key": "isDynamic", "value": "", "description": "true = dynamic playlists only; false = static playlists only", "disabled": true },
                { "key": "isDefault", "value": "", "description": "true = default playlists only", "disabled": true },
                { "key": "createdFrom", "value": "", "description": "Filter playlists created from this date (ISO 8601)", "disabled": true },
                { "key": "createdTo", "value": "", "description": "Filter playlists created up to this date (ISO 8601)", "disabled": true }
              ]
            },
            "description": "Get paginated list of playlists.\n\nAuth: SystemAdmin ✅, BrandManager (own brand) ✅, StoreManager (own store) ✅, PlaybackDevice ✅ (scope = Store của session; dùng Authorization: Bearer {{deviceAccessToken}}).\n\nNotes:\n- BrandManager: brandId is always overridden to their own brand.\n- StoreManager: storeId and brandId always overridden to their own store/brand.\n- PlaybackDevice: storeId/brandId lấy từ device session — chỉ thấy playlists thuộc Store đó.\n- SystemAdmin: can pass storeId or brandId to filter freely.\n- Includes: Mood (name), Store (name), PlaylistTracks (trackCount).\n- Default sort: newest first (isAscending = false)."
          },
          "response": [
            {
              "name": "200 OK — Playlist list",
              "originalRequest": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }],
                "url": {
                  "raw": "{{baseUrl}}/api/playlists?page=1&pageSize=10",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "playlists"],
                  "query": [
                    { "key": "page", "value": "1" },
                    { "key": "pageSize", "value": "10" }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"currentPage\": 1,\n  \"pageSize\": 10,\n  \"totalItems\": 1,\n  \"totalPages\": 1,\n  \"hasPrevious\": false,\n  \"hasNext\": false,\n  \"items\": [\n    {\n      \"id\": \"p1000000-0000-0000-0000-000000000001\",\n      \"brandId\": \"b0000000-0000-0000-0000-000000000001\",\n      \"storeId\": \"s0000000-0000-0000-0000-000000000001\",\n      \"storeName\": \"Store Alpha\",\n      \"moodId\": \"m0000000-0000-0000-0000-000000000001\",\n      \"moodName\": \"Relaxing\",\n      \"name\": \"Afternoon Chill\",\n      \"description\": \"Soft background music for afternoon hours\",\n      \"isDefault\": true,\n      \"trackCount\": 12,\n      \"createdAt\": \"2026-01-20T10:00:00Z\",\n      \"updatedAt\": null,\n      \"createdBy\": \"00000000-0000-0000-0000-000000000001\",\n      \"updatedBy\": null,\n      \"status\": 1\n    }\n  ],\n  \"isSuccess\": true,\n  \"message\": \"Playlist retrieved successfully\",\n  \"errors\": null,\n  \"errorCode\": null\n}"
            },
            {
              "name": "401 Unauthorized",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": { "raw": "{{baseUrl}}/api/playlists", "host": ["{{baseUrl}}"], "path": ["api", "playlists"] }
              },
              "status": "Unauthorized",
              "code": 401,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"isSuccess\": false,\n  \"message\": \"Unauthorized\",\n  \"errors\": null,\n  \"errorCode\": \"Unauthorized\"\n}"
            }
