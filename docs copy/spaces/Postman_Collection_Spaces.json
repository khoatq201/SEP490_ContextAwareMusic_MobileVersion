              "raw": "{{baseUrl}}/api/spaces/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "spaces", ":id"],
              "variable": [
                { "key": "id", "value": "c1d2e3f4-a5b6-7890-cdef-012345678901", "description": "Space ID (Guid)" }
              ]
