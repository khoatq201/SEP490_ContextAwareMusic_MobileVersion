                "key": "Accept-Language",
                "value": "vi-VN",
                "type": "text",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/spaces?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "spaces"],
              "query": [
                { "key": "page", "value": "1", "description": "Current page (default: 1)" },
                { "key": "pageSize", "value": "10", "description": "Items per page (default: 10, max: 500)" },
                { "key": "search", "value": "", "description": "Search by name / description", "disabled": true },
                { "key": "sortBy", "value": "", "description": "Field to sort by", "disabled": true },
                { "key": "isAscending", "value": "true", "description": "Sort direction (default: true = ascending)", "disabled": true },
                { "key": "status", "value": "1", "description": "Filter by status: 0=Inactive, 1=Active, 2=Pending, 3=Rejected", "disabled": true },
                { "key": "storeId", "value": "", "description": "⚠️ SM: always overridden. BM: use brandId instead. SA: free filter", "disabled": true },
                { "key": "brandId", "value": "", "description": "⚠️ BM: always overridden to their own brand. SA: filter by brand", "disabled": true },
                { "key": "type", "value": "", "description": "Filter by SpaceTypeEnum: 1=Counter, 2=Hall, 3=Entrance, 4=Outdoor, 5=Kitchen, 6=Restroom", "disabled": true },
                { "key": "createdFrom", "value": "", "description": "Filter spaces created from this date (ISO 8601)", "disabled": true },
                { "key": "createdTo", "value": "", "description": "Filter spaces created up to this date (ISO 8601)", "disabled": true }
              ]
            },
            "description": "Get paginated list of spaces.\n\nAuth: SystemAdmin ✅, BrandManager (own brand) ✅, StoreManager (own store) ✅. PlaybackDevice ❌ — tablet không được gọi GET list (mỗi Space gắn 1 device; dùng GET /api/spaces/{id} với id = SpaceId session).\n\nNotes:\n- BrandManager: brandId is always overridden to their own brand.\n- StoreManager: storeId is always overridden to their own store. SM with null storeId → 403.\n- SystemAdmin: can pass storeId or brandId to filter freely."
