            ],
            "url": {
              "raw": "{{baseUrl}}/api/cams/spaces/{{spaceId}}/queue/playlist",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cams", "spaces", "{{spaceId}}", "queue", "playlist"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"playlistId\": \"{{playlistId}}\",\n  \"mode\": 1,\n  \"isClearExistingQueue\": false,\n  \"reason\": \"Play playlist from Postman\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
