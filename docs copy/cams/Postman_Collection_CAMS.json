              "path": ["api", "cams", "spaces", "{{spaceId}}", "playback"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"command\": 9\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Báo server track đã kết thúc tự nhiên. Server sẽ advance tuần tự theo Position và áp dụng queueEndBehavior."
          },
          "response": []
        },
        {
          "name": "Add Tracks To Queue (PlayNow = 1)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
